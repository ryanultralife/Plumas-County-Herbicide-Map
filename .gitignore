# Auto-sync exclusions (sync-watch.ps1 runs `git add -A`, which honors this file)
.claude/
*.bak
*.bak2
*.bak3
*.bak4
*.tmp
*.corrupt.bak
*~
~$*
.DS_Store
Thumbs.db

# Regenerable build intermediates (raw data is in data/, embedded into index.html)
build/*.json
build/*.sqlite

# Bulk raw archives downloaded by the scraper (150-260 MB each; keep out of git)
data/raw/

# Transient SQLite sidecar files
*.sqlite-journal
*.sqlite-wal
*.sqlite-shm

# Python bytecode cache
__pycache__/
*.pyc
