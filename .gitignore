# Auto-sync exclusions (sync-watch.ps1 runs `git add -A`, which honors this file)
.claude/
*.bak
*.bak2
*.bak3
*.bak4
*.tmp
*.corrupt.bak
*~
~$*
.DS_Store
Thumbs.db

# Regenerable build intermediates (raw data is in data/, embedded into index.html)
build/*.json
build/*.sqlite

# Bulk raw archives downloaded by the scraper (150-260 MB each; keep out of git)
data/raw/

# Big data store + per-region per-row exports live in Supabase, not git.
# (Small map-ready aggregates go in data/agg/ instead.)
data/db/
data/exports/

# Transient SQLite sidecar files
*.sqlite-journal
*.sqlite-wal
*.sqlite-shm

# Python bytecode cache
__pycache__/
*.pyc

# Supabase CLI local cache
supabase/.temp/

# Big aggregated layer (regenerable; map reads Supabase map_agg or this if served)
data/agg/aggregated.geojson
